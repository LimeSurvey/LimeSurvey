[codespell]
# Paths to skip during checking
skip = vendor/,node_modules/,.git/,*.min.js,*.min.css,build/,dist/,upload/,.git/,.gitignore,.DS_Store,*.lock,*.lss,assets/packages/

# File types to check
check_filenames = true
check_hidden = false

# Dictionary to use
dictionaries = clear,rare

# Ignore words that are commonly false positives
ignore_words_list = clas,nd,ser,sav,nax,bu,fo,datas,rollin,optin,ded

# Exclude specific patterns
# Common false positives for LimeSurvey:
exclude_lines = 
    # Allow URLs
    ^.*https?://.*$
    # Allow specific code patterns that might look like typos but aren't
    # (Add specific patterns as needed)
